GEMINI_API_KEY=AIza...
NOTION_TOKEN=ntn_...

# Encryption key for sensitive per-user tokens (Notion token, Gemini API key)
# stored in Redis.  Generate once and keep secret — rotating this key will
# invalidate all existing stored tokens (users will need to reconnect Notion).
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
ENCRYPTION_KEY=

# Content Team — SEO Articles database
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Social Team — create a Notion database with columns:
#   Name (title), Platform (select), Status (select), Date Created (date)
#   Then paste the database ID here
NOTION_SOCIAL_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Agency Activity Log — central record of all completed tasks across all teams
# Create a Notion database with columns:
#   Name (title), Team (select), Type (select), Status (select),
#   Date (date), Link (url)
NOTION_AGENCY_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Video Director Team — video production briefs database
# Create a Notion database with columns:
#   Name (title), Platform (select), Duration (rich_text),
#   Visual Style (rich_text), Audio Mood (rich_text),
#   Hook Strategy (rich_text), Status (select), Date Created (date)
NOTION_VIDEO_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
